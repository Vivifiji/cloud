<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modèles de services cloud – IaaS, PaaS, SaaS, CaaS, FaaS</title>
<style>
  :root {
    --bg-primary: #ffffff;
    --bg-secondary: #f5f4f0;
    --bg-tertiary: #eeede8;
    --bg-info: #e6f1fb;
    --text-primary: #1a1a18;
    --text-secondary: #5a5a56;
    --text-tertiary: #9a9994;
    --text-info: #0c447c;
    --border-light: rgba(0,0,0,0.1);
    --border-medium: rgba(0,0,0,0.18);
    --border-info: #85b7eb;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 18px;
    --managed-bg: #E1F5EE;
    --managed-text: #085041;
    --managed-border: #5DCAA5;
    --user-bg: #FAEEDA;
    --user-text: #633806;
    --user-border: #EF9F27;
    --font: 'DM Sans', system-ui, sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg-primary: #1c1c1a;
      --bg-secondary: #242422;
      --bg-tertiary: #2c2c2a;
      --bg-info: #0c2a44;
      --text-primary: #e8e6de;
      --text-secondary: #a8a69e;
      --text-tertiary: #666460;
      --text-info: #85b7eb;
      --border-light: rgba(255,255,255,0.08);
      --border-medium: rgba(255,255,255,0.15);
      --border-info: #185fa5;
      --managed-bg: #04342c;
      --managed-text: #9fe1cb;
      --managed-border: #0f6e56;
      --user-bg: #412402;
      --user-text: #fac775;
      --user-border: #854f0b;
    }
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font);
    background: var(--bg-tertiary);
    color: var(--text-primary);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .card {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    border: 0.5px solid var(--border-light);
    padding: 2rem;
    width: 100%;
    max-width: 680px;
  }

  .card-header {
    margin-bottom: 1.5rem;
  }

  .card-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .card-sub {
    font-size: 13px;
    color: var(--text-tertiary);
  }

  .legend {
    display: flex;
    gap: 16px;
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .leg-dot {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    display: inline-block;
    margin-right: 5px;
    flex-shrink: 0;
    vertical-align: middle;
  }

  .model-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .tab {
    padding: 5px 14px;
    font-size: 12px;
    border: 0.5px solid var(--border-medium);
    border-radius: 20px;
    cursor: pointer;
    color: var(--text-secondary);
    background: var(--bg-primary);
    transition: all .15s;
    font-family: var(--font);
    user-select: none;
  }

  .tab:hover { background: var(--bg-secondary); }

  .tab.active {
    background: var(--bg-info);
    border-color: var(--border-info);
    color: var(--text-info);
    font-weight: 500;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: start;
  }

  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
  }

  .section-title {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-tertiary);
    letter-spacing: .04em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .stack {
    display: grid;
    gap: 5px;
  }

  .block {
    border-radius: 6px;
    padding: 7px 12px;
    font-size: 12px;
    font-weight: 500;
    text-align: center;
    border: 0.5px solid transparent;
    transition: all .2s;
    cursor: pointer;
    line-height: 1.3;
    font-family: var(--font);
  }

  .block:hover { opacity: 0.85; transform: translateX(2px); }

  .managed {
    background: var(--managed-bg);
    color: var(--managed-text);
    border-color: var(--managed-border);
  }

  .user {
    background: var(--user-bg);
    color: var(--user-text);
    border-color: var(--user-border);
  }

  .detail-card {
    background: var(--bg-secondary);
    border: 0.5px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 14px 16px;
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.7;
    min-height: 160px;
  }

  .detail-card strong {
    color: var(--text-primary);
    font-weight: 500;
  }

  .detail-card .model-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 8px;
    display: block;
  }

  .examples {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 0.5px solid var(--border-light);
    font-size: 12px;
    color: var(--text-tertiary);
  }

  .examples span {
    display: inline-block;
    background: var(--bg-tertiary);
    border: 0.5px solid var(--border-light);
    border-radius: 4px;
    padding: 2px 7px;
    margin: 2px 2px 0 0;
    color: var(--text-secondary);
  }

  .footer {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 0.5px solid var(--border-light);
    font-size: 11px;
    color: var(--text-tertiary);
    text-align: center;
  }
</style>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

<div class="card">
  <div class="card-header">
    <div class="card-title">Modèles de services cloud</div>
    <div class="card-sub">Qui gère quoi entre le fournisseur et vous ?</div>
  </div>

  <div class="legend">
    <span><span class="leg-dot" style="background:var(--managed-border)"></span>Géré par le fournisseur cloud</span>
    <span><span class="leg-dot" style="background:var(--user-border)"></span>Géré par vous (l'utilisateur)</span>
  </div>

  <div class="model-tabs" id="tabs"></div>

  <div class="grid">
    <div>
      <div class="section-title">Couches de la pile</div>
      <div class="stack" id="stack"></div>
    </div>
    <div>
      <div class="section-title">Description</div>
      <div class="detail-card" id="detail"></div>
    </div>
  </div>

  <div class="footer">Cliquez sur une couche pour en savoir plus · Cliquez sur un onglet pour changer de modèle</div>
</div>

<script>
const layers = [
  'Application',
  'Données',
  'Runtime',
  'Conteneurs',
  'Middleware',
  "Système d'exploitation",
  'Virtualisation',
  'Serveurs',
  'Stockage',
  'Réseau'
];

const models = {
  'on-prem': {
    label: 'On-premise',
    managed: [],
    title: 'On-premise – tout en interne',
    desc: 'Vous gérez <strong>l\'intégralité</strong> de la pile, du réseau physique jusqu\'à l\'application. C\'est le modèle classique d\'hébergement en datacenter interne : coûteux, mais contrôle total.',
    examples: []
  },
  'iaas': {
    label: 'IaaS',
    managed: ['Réseau','Stockage','Serveurs','Virtualisation'],
    title: 'IaaS – Infrastructure as a Service',
    desc: 'Le fournisseur gère le matériel et la virtualisation. <strong>Vous gérez</strong> le système d\'exploitation, le middleware, le runtime, et vos applications.',
    examples: ['Azure Virtual Machines','Amazon EC2','Google Compute Engine']
  },
  'caas': {
    label: 'CaaS',
    managed: ['Réseau','Stockage','Serveurs','Virtualisation',"Système d'exploitation",'Conteneurs'],
    title: 'CaaS – Container as a Service',
    desc: 'Extension de l\'IaaS : le fournisseur gère également <strong>l\'orchestration des conteneurs</strong> (Kubernetes). Vous déployez vos images sans vous soucier des nœuds.',
    examples: ['Azure Kubernetes Service','Amazon EKS','Google GKE']
  },
  'paas': {
    label: 'PaaS',
    managed: ['Réseau','Stockage','Serveurs','Virtualisation',"Système d'exploitation",'Conteneurs','Middleware','Runtime'],
    title: 'PaaS – Platform as a Service',
    desc: 'Le fournisseur prend en charge tout l\'environnement d\'exécution. <strong>Vous gérez uniquement</strong> votre code et vos données. Idéal pour les développeurs qui veulent se concentrer sur l\'application.',
    examples: ['Azure App Service','AWS Elastic Beanstalk','Google App Engine']
  },
  'faas': {
    label: 'FaaS',
    managed: ['Réseau','Stockage','Serveurs','Virtualisation',"Système d'exploitation",'Conteneurs','Middleware','Runtime'],
    title: 'FaaS – Function as a Service (serverless)',
    desc: 'Vous déployez des <strong>fonctions individuelles</strong> déclenchées par des événements. L\'infrastructure est totalement invisible, la facturation est à l\'exécution.',
    examples: ['Azure Functions','AWS Lambda','Google Cloud Functions']
  },
  'saas': {
    label: 'SaaS',
    managed: ['Réseau','Stockage','Serveurs','Virtualisation',"Système d'exploitation",'Conteneurs','Middleware','Runtime','Application','Données'],
    title: 'SaaS – Software as a Service',
    desc: 'Le fournisseur gère <strong>tout</strong>, y compris l\'application et les données. Vous utilisez simplement le logiciel via un navigateur.',
    examples: ['Microsoft 365','Google Workspace','Salesforce','Slack']
  }
};

let current = 'iaas';

function renderTabs() {
  const container = document.getElementById('tabs');
  container.innerHTML = Object.entries(models).map(([key, m]) =>
    `<div class="tab${key === current ? ' active' : ''}" onclick="show('${key}')">${m.label}</div>`
  ).join('');
}

function show(key) {
  current = key;
  const m = models[key];
  renderTabs();

  const stack = document.getElementById('stack');
  stack.innerHTML = [...layers].reverse().map(l => {
    const isManaged = m.managed.includes(l);
    const cls = isManaged ? 'managed' : 'user';
    return `<div class="block ${cls}" onclick="clickLayer('${l.replace(/'/g,"\\'")}', event)">${l}</div>`;
  }).join('');

  renderDetail(m.title, m.desc, m.examples);
}

function renderDetail(title, desc, examples) {
  const exHtml = examples && examples.length
    ? `<div class="examples">Exemples : ${examples.map(e => `<span>${e}</span>`).join('')}</div>`
    : '';
  document.getElementById('detail').innerHTML =
    `<span class="model-name">${title}</span>${desc}${exHtml}`;
}

function clickLayer(l, e) {
  const m = models[current];
  const isManaged = m.managed.includes(l);
  const who = isManaged ? 'le fournisseur cloud' : 'vous (l\'utilisateur)';
  const color = isManaged ? 'var(--managed-text)' : 'var(--user-text)';
  document.getElementById('detail').innerHTML =
    `<span class="model-name">${l}</span>` +
    `Cette couche est gérée par <strong style="color:${color}">${who}</strong> dans le modèle <strong>${m.label}</strong>.<br><br>${m.desc}` +
    (m.examples && m.examples.length
      ? `<div class="examples">Exemples : ${m.examples.map(ex => `<span>${ex}</span>`).join('')}</div>`
      : '');
}

show('iaas');
</script>
</body>
</html>
